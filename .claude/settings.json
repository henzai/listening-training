{
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint",
            "if": "Bash(git commit*)",
            "statusMessage": "Running Biome lint check..."
          }
        ]
      }
    ]
  }
}
